POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=israel_gtfs
POSTGRES_PORT=5432
LOCAL_TZ=Asia/Jerusalem

VITE_API_BASE=http://127.0.0.1:8000/api/v1

GRAPH_WARMUP_ENABLED=true
GRAPH_WARMUP_TIMEOUT_S=300
GRAPH_WARMUP_PROFILES=weekday,friday,saturday,sunday

HYBRID_DETOUR_ENABLED=true

# Detour v3 (PostGIS bus-corridor graph). Docker compose sets these on backend/frontend by default.
DETOUR_V3_ENABLED=true
DETOUR_ENGINE=v3
DETOUR_V3_COST_MODE=bus_corridor_plus_connectors
# DETOUR_V3_IMPORT_RUN_ID=4
# Use host Postgres from Docker (feed 21 + v3 tables). Copy these into `.env`:
# DATABASE_URL=postgresql://postgres@host.docker.internal:5432/israel_gtfs
# DETOUR_V3_IMPORT_RUN_ID=4
# GRAPH_WARMUP_PREVIEWS_ENABLED=false
VITE_DETOUR_COMPUTE_ENGINE=v3
